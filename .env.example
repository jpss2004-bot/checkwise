# CheckWise environment template.
#
# Copy to backend/.env (consumed by app.core.config) and to
# frontend/.env.local (consumed by Next.js — only NEXT_PUBLIC_* vars
# reach the browser).
#
# Never commit a populated .env file. The patterns in .gitignore
# already block .env and .env.* (with .env.example explicitly allowed).

# ── Runtime ──────────────────────────────────────────────────────────
CHECKWISE_ENV=local
# In prod set: CHECKWISE_ENV=production

# ── Database (PostgreSQL) ───────────────────────────────────────────
# Local dev (via docker-compose):
DATABASE_URL=postgresql+psycopg://checkwise:checkwise@localhost:5432/checkwise
# Prod (Neon or any managed Postgres). Use the *pooled* connection
# string for runtime; some setups need a separate direct URL for Alembic:
#   DATABASE_URL=postgresql+psycopg://<user>:<password>@<pooled-host>/<db>?sslmode=require
#   DIRECT_DATABASE_URL=postgresql+psycopg://<user>:<password>@<direct-host>/<db>?sslmode=require

# ── CORS ────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# In prod set the exact frontend origin(s), comma-separated:
#   CORS_ORIGINS=https://checkwise.app,https://www.checkwise.app

# ── Storage ─────────────────────────────────────────────────────────
# Local FS for dev. Vercel and most serverless platforms cannot use
# this — switch to s3 / r2 / gcs in any deployed environment.
STORAGE_BACKEND=local
STORAGE_BUCKET=checkwise-local
LOCAL_STORAGE_PATH=./storage
STORAGE_PUBLIC_BASE_URL=
# Prod-only placeholders (uncomment + populate when switching to S3/R2/GCS):
#   STORAGE_BACKEND=s3
#   STORAGE_BUCKET=checkwise-prod
#   STORAGE_PUBLIC_BASE_URL=https://cdn.checkwise.app
#   AWS_ACCESS_KEY_ID=
#   AWS_SECRET_ACCESS_KEY=
#   AWS_REGION=
#   AWS_S3_ENDPOINT=                # set for R2/MinIO; leave empty for AWS S3

# ── Upload validation ───────────────────────────────────────────────
MAX_UPLOAD_SIZE_BYTES=15728640
ALLOWED_FILE_EXTENSIONS=.pdf

# ── Auth / JWT ──────────────────────────────────────────────────────
# Default below is a safe local-dev placeholder. In any non-local
# environment, override AUTH_JWT_SECRET with a strong random value
# (min 32 chars). Rotate periodically. Never commit the real one.
AUTH_JWT_SECRET=checkwise-local-dev-secret-change-me-please-min-32-chars
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_EXPIRES_MINUTES=1440
AUTH_BCRYPT_ROUNDS=12

# ── Email (planned, not yet wired) ──────────────────────────────────
# Welcome-email and correction-notification transport. Will be consumed
# by lib/email/* on the backend once the activation API ships.
#   EMAIL_PROVIDER=resend            # resend | postmark | ses
#   EMAIL_FROM=no-reply@checkwise.app
#   EMAIL_API_KEY=
#   EMAIL_SMTP_HOST=
#   EMAIL_SMTP_PORT=587
#   EMAIL_SMTP_USER=
#   EMAIL_SMTP_PASSWORD=

# ── Observability (planned) ─────────────────────────────────────────
#   SENTRY_DSN=
#   LOG_LEVEL=INFO

# ── Support links (display only) ────────────────────────────────────
SUPPORT_WHATSAPP_URL=
SUPPORT_QR_PLACEHOLDER_URL=

# ── Frontend (Next.js, only NEXT_PUBLIC_* reaches the browser) ──────
# These belong in frontend/.env.local (NOT backend/.env), but the
# template lives here so the full picture is in one place.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_WHATSAPP_SUPPORT_URL=
NEXT_PUBLIC_SUPPORT_QR_PLACEHOLDER_URL=
# Set to "true" to expose the "Usar PDF demo" button. Leave unset for prod.
NEXT_PUBLIC_DEMO_MODE=
