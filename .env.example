# CheckWise environment template.
#
# Copy to apps/api/.env (consumed by app.core.config) and to
# apps/web/.env.local (consumed by Next.js — only NEXT_PUBLIC_* vars
# reach the browser).
#
# Never commit a populated .env file. The patterns in .gitignore
# already block .env and .env.* (with .env.example explicitly allowed).

# ── Runtime ──────────────────────────────────────────────────────────
CHECKWISE_ENV=local
# In prod set: CHECKWISE_ENV=production

# ── Database (PostgreSQL) ───────────────────────────────────────────
# Local dev (via docker-compose):
DATABASE_URL=postgresql+psycopg://checkwise:checkwise@localhost:5432/checkwise
# Prod (Neon or any managed Postgres). Use the *pooled* connection
# string for runtime; some setups need a separate direct URL for Alembic:
#   DATABASE_URL=postgresql+psycopg://<user>:<password>@<pooled-host>/<db>?sslmode=require
#   DIRECT_DATABASE_URL=postgresql+psycopg://<user>:<password>@<direct-host>/<db>?sslmode=require

# ── CORS ────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Reports AI (Phase 3.3+) ────────────────────────────────────────
# Anthropic Claude powers the report planner + per-block content
# generator. Leave ANTHROPIC_API_KEY empty to fall back to the
# deterministic mock LLM client (used in CI and in dev without a key).
# Set CHECKWISE_LLM_BACKEND=mock to force the mock even when a key is
# present (e.g. for reproducible local runs); =anthropic to force
# the real client (fails if no key). Empty = auto-detect.
ANTHROPIC_API_KEY=
CHECKWISE_LLM_BACKEND=
# In prod set the exact frontend origin(s), comma-separated:
#   CORS_ORIGINS=https://checkwise.app,https://www.checkwise.app

# ── Storage ─────────────────────────────────────────────────────────
# Local FS for dev. Render's filesystem is ephemeral and Vercel's
# serverless runtime can't use it — switch STORAGE_BACKEND=s3 in any
# deployed environment.
STORAGE_BACKEND=local
STORAGE_BUCKET=checkwise-local
# Relative paths anchor to apps/api (NOT the process CWD); absolute
# paths are used as-is. Applies to LOCAL_STORAGE_PATH and
# METADATA_EXPORT_PATH (default ./metadata_exports). When
# STORAGE_BACKEND=s3, metadata XLSX exports are additionally mirrored
# to the bucket under metadata_exports/ so they survive Render deploys.
LOCAL_STORAGE_PATH=./storage
METADATA_EXPORT_PATH=./metadata_exports
# Automatic per-upload XLSX metadata tables (+ the per-client master
# workbook). Best-effort: a failed export never blocks the provider's
# upload; it records a `metadata_table_exported` ValidationEvent either way.
AUTO_METADATA_EXPORT_ENABLED=true
STORAGE_PUBLIC_BASE_URL=
# Prod (Cloudflare R2 / AWS S3 / MinIO). Uncomment + populate to switch:
#   STORAGE_BACKEND=s3
#   STORAGE_BUCKET=checkwise-prod
#   AWS_ACCESS_KEY_ID=
#   AWS_SECRET_ACCESS_KEY=
#   AWS_REGION=auto                  # use "auto" for R2; an AWS region for S3
#   AWS_S3_ENDPOINT=                 # https://<account_id>.r2.cloudflarestorage.com for R2; leave empty for AWS S3
#   S3_PRESIGNED_URL_TTL_SECONDS=900

# ── Upload validation ───────────────────────────────────────────────
MAX_UPLOAD_SIZE_BYTES=15728640
ALLOWED_FILE_EXTENSIONS=.pdf
# Deprecated/prototyping upload surfaces. Unset means local-only route
# registration; set true only for a deliberate non-local debugging window.
# Set false to remove them even in local.
EXPOSE_LEGACY_SUBMISSIONS=
EXPOSE_METADATA_DRY_RUN=

# ── Auth / JWT ──────────────────────────────────────────────────────
# Default below is a safe local-dev placeholder. In any non-local
# environment, override AUTH_JWT_SECRET with a strong random value
# (min 32 chars). Rotate periodically. Never commit the real one.
AUTH_JWT_SECRET=checkwise-local-dev-secret-change-me-please-min-32-chars
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_EXPIRES_MINUTES=1440
AUTH_BCRYPT_ROUNDS=12
FRONTEND_BASE_URL=http://localhost:3000
PASSWORD_RESET_EXPIRES_MINUTES=60
# Provider-portal session cookie (httpOnly, signed). Secure is set
# automatically whenever CHECKWISE_ENV != local.
PORTAL_SESSION_COOKIE_NAME=checkwise_portal_session
PORTAL_SESSION_EXPIRES_MINUTES=1440

# ── Rate limits ─────────────────────────────────────────────────────
# Sliding-window limits. Backing store is selected by REDIS_URL:
# empty → in-memory (correct on a SINGLE uvicorn worker only — every
# extra worker silently multiplies the effective limits by N);
# any redis:// / rediss:// URL → shared limiter that holds across the
# whole API cluster. Provision Redis BEFORE raising Render's worker
# count above 1. Setting a limit to 0 disables that bucket.
AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=10
AUTH_FORGOT_PASSWORD_RATE_LIMIT_PER_HOUR=5
SHARE_UNLOCK_RATE_LIMIT_PER_MINUTE=5
SHARE_UNLOCK_RATE_LIMIT_PER_HOUR=30
AI_HEAVY_RATE_LIMIT_PER_MINUTE=15
AI_HEAVY_RATE_LIMIT_PER_HOUR=120
REDIS_URL=
# Per-call Redis timeout (ms) on the limiter hot path. Failures are
# fail-closed (500) so a Redis outage surfaces instead of silently
# disabling brute-force protection.
REDIS_RATE_LIMIT_TIMEOUT_MS=250

# ── Feature flags ───────────────────────────────────────────────────
# Multi-file submissions (up to 5 files / 30 MB per submission, used
# for contract + anexos). ON by default since 2026-05-25. This is the
# BACKEND half of the kill switch — the intake wizard's dropzone is
# gated separately by NEXT_PUBLIC_MULTI_FILE_UPLOAD_ENABLED (frontend
# section below); set BOTH to false to roll the feature back without
# a deploy.
MULTI_FILE_UPLOAD_ENABLED=true
# Collapsed recurring catalog v2 (one row per institution+period with
# an accepts_documents list) vs legacy v1 (one row per doc name).
# Dark-shipped 2026-05-20; v1 stays authoritative while false.
RECURRING_CATALOG_V2=false
# /docs, /redoc, /openapi.json. Empty → enabled in local only.
# "true"/"false" force it on/off in any environment.
ENABLE_API_DOCS=

# ── Password reset email ────────────────────────────────────────────
# Configure these with the mailbox that should send reset links. For
# Gmail/Google Workspace, use an app password rather than your normal
# login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=CheckWise
SMTP_USE_TLS=true
SMTP_USE_SSL=false
# Older names are also accepted for compatibility with existing Render envs:
# EMAIL_SMTP_HOST, EMAIL_SMTP_PORT, EMAIL_SMTP_USER, EMAIL_SMTP_PASSWORD, EMAIL_FROM

# ── Document AI / OCR (Phase 3 — scanned-PDF fallback) ─────────────
# Optional. OCR runs synchronously during intake when
# `inspect_pdf_with_ocr_fallback` flags a scanned document. Default
# OFF — uploads without extracted text route to `pendiente_revision`
# and the extraction pipeline still works (just without OCR).
#
# To enable in any environment:
#   1. Provision a Google Cloud project.
#   2. Enable the Document AI API.
#   3. Create an Enterprise Document OCR processor.
#   4. Mint a service account with `documentai.editor`.
#   5. Export the JSON key, paste its full contents (one line) into
#      GOOGLE_APPLICATION_CREDENTIALS_JSON below.
# Step-by-step: apps/api/docs/PHASE3_DOCUMENTAI_SETUP.md
OCR_ENABLED=false
GOOGLE_DOC_AI_PROJECT_ID=
GOOGLE_DOC_AI_LOCATION=us
GOOGLE_DOC_AI_PROCESSOR_ID=
GOOGLE_APPLICATION_CREDENTIALS_JSON=
OCR_TIMEOUT_SECONDS=30

# ── Phase 2 — Anthropic Claude document analysis (shadow mode) ─────
# Optional. The inline heuristic classifier in
# `services.document_intelligence` always runs and drives the
# user-visible status; these settings only control the background
# shadow runner that calls Claude on the uploaded PDF and persists a
# second extraction to the `document_inspections.shadow_*` columns
# for offline comparison. ZDR must be confirmed on the Anthropic
# account before flipping the provider to `anthropic` in production.
#
# DOCUMENT_ANALYSIS_PROVIDER values:
#   disabled  — no shadow runs (default).
#   heuristic — shadow runs the regex baseline (plumbing test only).
#   anthropic — Claude reads the PDF and extracts.
#   shadow    — alias for `anthropic`.
#
# Reuses ANTHROPIC_API_KEY from the Reports/Wise block above.
DOCUMENT_ANALYSIS_PROVIDER=disabled
# Tiered analysis (Phase C): every shadow-analyzed upload runs the
# cheap TRIAGE model first; suspicious results (or high-stakes
# requirements) re-run on the escalation model. DOCUMENT_ANALYSIS_MODEL
# keeps its historical name for Render compat but is the ESCALATION
# model, not the per-upload default.
DOCUMENT_ANALYSIS_MODEL=claude-sonnet-4-6
DOCUMENT_ANALYSIS_TRIAGE_MODEL=claude-haiku-4-5
DOCUMENT_ANALYSIS_TIMEOUT_SECONDS=30
DOCUMENT_ANALYSIS_MAX_FILE_MB=30
DOCUMENT_ANALYSIS_MAX_PAGES=100
# Per-org daily call cap. 0 disables the cap entirely. 200/day is a
# conservative pilot ceiling; raise after a few days of telemetry.
DOCUMENT_ANALYSIS_DAILY_CAP_PER_ORG=200
# Separate daily cap for escalation-tier (expensive model) re-runs.
# Counted independently of the triage cap; exhaustion skips the
# escalation gracefully (the triage result stands). 0 disables.
DOCUMENT_ANALYSIS_ESCALATION_DAILY_CAP_PER_ORG=50
# Phase 3 pilot-cohort allowlist. CSV of `client.id` values; when
# set, only listed orgs get shadow runs. Empty = every org is in
# scope. Used to limit the first 24h of `provider=anthropic` to a
# named test workspace.
DOCUMENT_ANALYSIS_PILOT_ORG_IDS=

# ── Phase E — approval suggestion + auto-approve (ships DARK) ───────
# AUTO_APPROVE_SUGGEST_CONFIDENCE gates the reviewer-facing
# "sugerimos aprobar" hint (advisory only — never changes a status).
# The auto-approve engine itself is dark by default:
#   AUTO_APPROVE_ENABLED is the master kill switch (OFF — nothing is
#   ever auto-approved until an operator flips it deliberately).
#   AUTO_APPROVE_UNLOCKED_REQUIREMENT_CODES is a CSV allowlist of
#   requirement codes unlocked one at a time, each backed by a
#   calibration-harness report proving ≥99% precision for that
#   document type. Empty = nothing unlocked even with the master on.
#   AUTO_APPROVE_MIN_CONFIDENCE is the per-document floor on match
#   confidence — deliberately stricter than the suggestion threshold.
AUTO_APPROVE_SUGGEST_CONFIDENCE=0.9
AUTO_APPROVE_ENABLED=false
AUTO_APPROVE_UNLOCKED_REQUIREMENT_CODES=
AUTO_APPROVE_MIN_CONFIDENCE=0.97

# ── Messaging fanout — SMS via Twilio, WhatsApp via Meta ───────────
# MESSAGING_ENABLED is the master gate for the unified notification
# fanout. Without it the dispatcher writes `whatsapp_status="skipped"`
# rows and no SMS / WhatsApp leaves the box.
#
# Twilio SMS is the active outbound channel today. Native WhatsApp
# template delivery is gated on (a) Meta approval of the templates
# in docs/runbooks/whatsapp_templates.json AND (b) flipping
# WHATSAPP_NATIVE_TEMPLATES_ENABLED=true. While the flag is off, the
# fanout passes ``whatsapp_components=None`` to ``send_message`` and
# falls through to Twilio SMS with the rendered plaintext body —
# exactly today's behavior. The WHATSAPP_* keys below are also used
# by the phone-verification OTP path (see apps/api/app/api/v1/me.py:356)
# which calls Meta directly, outside the fanout.
MESSAGING_ENABLED=false

TWILIO_ENABLED=false
TWILIO_DRY_RUN=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

WHATSAPP_ENABLED=false
WHATSAPP_DRY_RUN=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_DEFAULT_LANGUAGE_CODE=es_MX
WHATSAPP_DEFAULT_COUNTRY_CODE=52

# Reverse-cutover gate. Flip ON only after Meta has APPROVED the
# templates (cw_renewal_threshold, cw_reviewer_decision) AND
# WHATSAPP_ENABLED=true. While False (default), the fanout sends
# every WhatsApp-eligible event via Twilio SMS with the plaintext
# body. While True, renewal + verification events go via Meta as
# native templates; events without a builder (reporting, account
# invitation) still fall through to SMS.
WHATSAPP_NATIVE_TEMPLATES_ENABLED=false

# ── Observability (planned) ─────────────────────────────────────────
#   SENTRY_DSN=
#   LOG_LEVEL=INFO

# ── Slack delivery (all optional, all fail-soft) ────────────────────
# Public landing-page contact form (POST /api/v1/contact) always
# persists submissions to the `contact_requests` table. Setting this
# optional Slack incoming-webhook URL ALSO delivers each new request
# to a channel in real time. Leave empty to disable Slack delivery
# without touching code — persistence is unaffected.
SLACK_CONTACT_WEBHOOK_URL=
# Internal tester feedback (bug/improvement reports with screenshot).
# Needs a Slack BOT token (xoxb-…) because the PNG attach uses
# files.upload_v2, which incoming webhooks don't support. Both empty →
# the endpoint still 202s with delivered=false.
SLACK_BOT_TOKEN=
SLACK_FEEDBACK_CHANNEL_ID=
# Provider Tier-B correction requests (contact email/phone/name changes
# from the workspace context bar). Incoming-webhook URL; empty →
# audit-log persistence only. May point at the same channel as feedback.
SLACK_CORRECTION_WEBHOOK_URL=

# ── Support links (display only) ────────────────────────────────────
SUPPORT_WHATSAPP_URL=
SUPPORT_QR_PLACEHOLDER_URL=

# ── Frontend (Next.js, only NEXT_PUBLIC_* reaches the browser) ──────
# These belong in apps/web/.env.local (NOT apps/api/.env), but the
# template lives here so the full picture is in one place.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_WHATSAPP_SUPPORT_URL=
NEXT_PUBLIC_SUPPORT_QR_PLACEHOLDER_URL=
# Set to "true" to expose the "Usar PDF demo" button. Leave unset for prod.
NEXT_PUBLIC_DEMO_MODE=
# Frontend half of the multi-file kill switch (the dropzone UI).
# Anything except the literal "false" counts as ON. Pair with the
# backend MULTI_FILE_UPLOAD_ENABLED flag above when rolling back.
NEXT_PUBLIC_MULTI_FILE_UPLOAD_ENABLED=
# NEXT_PUBLIC_APP_VERSION / NEXT_PUBLIC_GIT_SHA are injected by the
# build (Vercel) for the version badge — no need to set them locally.
