# CheckWise environment template.
#
# Copy to backend/.env (consumed by app.core.config) and to
# frontend/.env.local (consumed by Next.js — only NEXT_PUBLIC_* vars
# reach the browser).
#
# Never commit a populated .env file. The patterns in .gitignore
# already block .env and .env.* (with .env.example explicitly allowed).

# ── Runtime ──────────────────────────────────────────────────────────
CHECKWISE_ENV=local
# In prod set: CHECKWISE_ENV=production

# ── Database (PostgreSQL) ───────────────────────────────────────────
# Local dev (via docker-compose):
DATABASE_URL=postgresql+psycopg://checkwise:checkwise@localhost:5432/checkwise
# Prod (Neon or any managed Postgres). Use the *pooled* connection
# string for runtime; some setups need a separate direct URL for Alembic:
#   DATABASE_URL=postgresql+psycopg://<user>:<password>@<pooled-host>/<db>?sslmode=require
#   DIRECT_DATABASE_URL=postgresql+psycopg://<user>:<password>@<direct-host>/<db>?sslmode=require

# ── CORS ────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Reports AI (Phase 3.3+) ────────────────────────────────────────
# Anthropic Claude powers the report planner + per-block content
# generator. Leave ANTHROPIC_API_KEY empty to fall back to the
# deterministic mock LLM client (used in CI and in dev without a key).
# Set CHECKWISE_LLM_BACKEND=mock to force the mock even when a key is
# present (e.g. for reproducible local runs); =anthropic to force
# the real client (fails if no key). Empty = auto-detect.
ANTHROPIC_API_KEY=
CHECKWISE_LLM_BACKEND=
# In prod set the exact frontend origin(s), comma-separated:
#   CORS_ORIGINS=https://checkwise.app,https://www.checkwise.app

# ── Storage ─────────────────────────────────────────────────────────
# Local FS for dev. Render's filesystem is ephemeral and Vercel's
# serverless runtime can't use it — switch STORAGE_BACKEND=s3 in any
# deployed environment.
STORAGE_BACKEND=local
STORAGE_BUCKET=checkwise-local
LOCAL_STORAGE_PATH=./storage
STORAGE_PUBLIC_BASE_URL=
# Prod (Cloudflare R2 / AWS S3 / MinIO). Uncomment + populate to switch:
#   STORAGE_BACKEND=s3
#   STORAGE_BUCKET=checkwise-prod
#   AWS_ACCESS_KEY_ID=
#   AWS_SECRET_ACCESS_KEY=
#   AWS_REGION=auto                  # use "auto" for R2; an AWS region for S3
#   AWS_S3_ENDPOINT=                 # https://<account_id>.r2.cloudflarestorage.com for R2; leave empty for AWS S3
#   S3_PRESIGNED_URL_TTL_SECONDS=900

# ── Upload validation ───────────────────────────────────────────────
MAX_UPLOAD_SIZE_BYTES=15728640
ALLOWED_FILE_EXTENSIONS=.pdf

# ── Auth / JWT ──────────────────────────────────────────────────────
# Default below is a safe local-dev placeholder. In any non-local
# environment, override AUTH_JWT_SECRET with a strong random value
# (min 32 chars). Rotate periodically. Never commit the real one.
AUTH_JWT_SECRET=checkwise-local-dev-secret-change-me-please-min-32-chars
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_EXPIRES_MINUTES=1440
AUTH_BCRYPT_ROUNDS=12
FRONTEND_BASE_URL=http://localhost:3000
PASSWORD_RESET_EXPIRES_MINUTES=60

# ── Password reset email ────────────────────────────────────────────
# Configure these with the mailbox that should send reset links. For
# Gmail/Google Workspace, use an app password rather than your normal
# login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=CheckWise
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# ── Observability (planned) ─────────────────────────────────────────
#   SENTRY_DSN=
#   LOG_LEVEL=INFO

# ── Contact form delivery (P0-3) ────────────────────────────────────
# Public landing-page contact form (POST /api/v1/contact) always
# persists submissions to the `contact_requests` table. Setting this
# optional Slack incoming-webhook URL ALSO delivers each new request
# to a channel in real time. Leave empty to disable Slack delivery
# without touching code — persistence is unaffected.
SLACK_CONTACT_WEBHOOK_URL=

# ── Support links (display only) ────────────────────────────────────
SUPPORT_WHATSAPP_URL=
SUPPORT_QR_PLACEHOLDER_URL=

# ── Frontend (Next.js, only NEXT_PUBLIC_* reaches the browser) ──────
# These belong in frontend/.env.local (NOT backend/.env), but the
# template lives here so the full picture is in one place.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_WHATSAPP_SUPPORT_URL=
NEXT_PUBLIC_SUPPORT_QR_PLACEHOLDER_URL=
# Set to "true" to expose the "Usar PDF demo" button. Leave unset for prod.
NEXT_PUBLIC_DEMO_MODE=
