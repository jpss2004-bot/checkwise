# OS
.DS_Store
.Spotlight-V100
.Trashes
.AppleDouble

# Env (never commit populated env files)
.env
.env.*
!.env.example
!frontend/.env.local.example

# Secrets and certificates — defense in depth on top of .env
*.pem
*.key
*.p12
*.pfx
*.crt
service-account*.json
*credentials*.json
*-secret.json

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
backend/.venv/
backend/storage/
backend/uploads/
backend/*.egg-info/

# Node / Next.js
node_modules/
.next/
out/
dist/
coverage/
frontend/node_modules/
frontend/.next/
frontend/.cw-next-*/
frontend/out/
frontend/.turbo/
*.tsbuildinfo

# Vercel local
.vercel/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
tmp/
uploads/
!docs/design-system/claude-design-v0.1/uploads/
