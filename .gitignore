apps/web/.next/
apps/web/.cw-next-*/
apps/web/out/
apps/web/.turbo/
*.tsbuildinfo

# Vercel local
.vercel/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
tmp/
uploads/
