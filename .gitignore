# OS
.DS_Store
.Spotlight-V100
.Trashes
.AppleDouble

# Env (never commit populated env files)
.env
.env.*
!.env.example
!apps/web/.env.local.example

# Secrets and certificates — defense in depth on top of .env
*.pem
*.key
*.p12
*.pfx
*.crt
service-account*.json
*credentials*.json
*-secret.json

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
apps/api/.venv/
apps/api/storage/
apps/api/uploads/
apps/api/metadata_exports/
apps/api/*.egg-info/

