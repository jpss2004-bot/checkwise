__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
apps/api/.venv/
apps/api/storage/
apps/api/uploads/
apps/api/metadata_exports/
apps/api/*.egg-info/

# Repo-root runtime artifacts left behind by processes launched from the
