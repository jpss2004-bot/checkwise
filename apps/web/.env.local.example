NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_WHATSAPP_SUPPORT_URL=
NEXT_PUBLIC_SUPPORT_QR_PLACEHOLDER_URL=
# Set to "true" to expose the "Usar PDF demo" button in the intake wizard.
# Defaults to "false" — leave it that way in production (audit P4-06,
# 2026-05-25). Flip to "true" only when working locally against a
# clean Neon DB so the demo PDF helper is reachable.
NEXT_PUBLIC_DEMO_MODE=false
# NEXT_PUBLIC_DEV_ROUTES used to gate /dev/calendar-preview (audit
# P4-05). The route was deleted entirely on 2026-05-25 — the
# designer sandbox lives in Figma now and the gate is no longer
# needed. Leaving this comment so a future re-introduction of /dev/*
# routes lands on the same env-var convention.
# Frontend half of the multi-file upload kill switch (intake-wizard
# dropzone). Anything except the literal "false" counts as ON. The
# backend half is MULTI_FILE_UPLOAD_ENABLED in apps/api/.env — set
# both to false to roll the feature back without a deploy.
NEXT_PUBLIC_MULTI_FILE_UPLOAD_ENABLED=
