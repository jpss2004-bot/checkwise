NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_WHATSAPP_SUPPORT_URL=
NEXT_PUBLIC_SUPPORT_QR_PLACEHOLDER_URL=
# Set to "true" to expose the "Usar PDF demo" button in the intake wizard.
# Defaults to "false" — leave it that way in production (audit P4-06,
# 2026-05-25). Flip to "true" only when working locally against a
# clean Neon DB so the demo PDF helper is reachable.
NEXT_PUBLIC_DEMO_MODE=false
# Set to "true" to expose the /dev/* designer sandbox routes (today:
# /dev/calendar-preview). Defaults to "false"; the page returns 404
# outside local. Flip to "true" only in local dev or an opted-in
# private staging tier (audit P4-05, 2026-05-25).
NEXT_PUBLIC_DEV_ROUTES=false
